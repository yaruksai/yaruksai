# YARUKSAİ Environment Variables
# ─────────────────────────────────

# LLM Provider (default: ollama)
LLM_PROVIDER=ollama

# Ollama (Local — Primary)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:1b

# Groq (Cloud — Optional Boost)
# Set GROQ_BOOST=1 to enable Groq for heavy stages
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BOOST=0

# Pipeline
MAX_CONCURRENT_RUNS=2
ARTIFACT_ROOT=/app/artifacts
SSE_PING_SECONDS=3

# Security
NODE_ENV=production
